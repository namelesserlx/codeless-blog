{
    "name": "codeless-blog",
    "version": "1.0.0",
    "private": true,
    "description": "Full-stack blog and CMS monorepo built with Next.js 16, React 19, Koa 3, Prisma 7, and MeiliSearch.",
    "engines": {
        "node": ">=22.0.0"
    },
    "packageManager": "pnpm@10.15.0",
    "scripts": {
        "dev:blog": "APP_ENV=development turbo run dev --filter=@blog/next",
        "dev:admin": "APP_ENV=development turbo run dev --filter=@blog/client",
        "dev:server": "APP_ENV=development turbo run dev --filter=@blog/server",
        "build:blog": "turbo run build --filter=@blog/next",
        "build:admin": "turbo run build --filter=@blog/client",
        "build:server": "turbo run build --filter=@blog/server",
        "build": "turbo run build",
        "dev": "APP_ENV=development turbo run dev",
        "ci:baseline": "pnpm --filter @blog/server test && pnpm --filter @blog/db test && pnpm --filter @blog/shared build && pnpm --filter @blog/config check",
        "ci:lint": "pnpm lint",
        "ci:build": "pnpm build:server && pnpm build:blog && pnpm build:admin",
        "ci:quality": "pnpm ci:lint && pnpm ci:baseline && pnpm ci:build",
        "lint": "turbo run lint",
        "format": "turbo run format",
        "docker:up:staging": "APP_ENV=staging sh ./scripts/docker-up.sh",
        "docker:up:production": "APP_ENV=production sh ./scripts/docker-up.sh",
        "docker:down:staging": "docker compose --env-file .env.staging down",
        "docker:down:production": "docker compose --env-file .env.production down",
        "docker:logs:staging": "docker compose --env-file .env.staging logs -f",
        "docker:logs:production": "docker compose --env-file .env.production logs -f",
        "docker:ps:staging": "docker compose --env-file .env.staging ps",
        "docker:ps:production": "docker compose --env-file .env.production ps",
        "db:generate": "turbo run db:generate --filter=@blog/db",
        "db:push": "turbo run db:push --filter=@blog/db",
        "db:studio": "turbo run db:studio --filter=@blog/db",
        "db:migrate:dev": "turbo run db:migrate:dev --filter=@blog/db",
        "db:migrate:deploy": "turbo run db:migrate:deploy --filter=@blog/db",
        "db:reset": "turbo run db:reset --filter=@blog/db",
        "db:seed": "turbo run db:seed --filter=@blog/db",
        "db:sync-permissions": "pnpm --filter @blog/server sync-permissions:dev",
        "clean:server": "pkill -9 -f 'ts-node-dev.*app.ts' 2>/dev/null; lsof -ti :8000 | xargs kill -9 2>/dev/null; echo '✅ Server 进程已清理'",
        "prepare": "husky"
    },
    "keywords": [
        "nextjs",
        "react",
        "koa",
        "prisma",
        "meilisearch",
        "tailwindcss",
        "typescript",
        "monorepo",
        "blog",
        "cms",
        "rbac",
        "pwa"
    ],
    "author": {
        "name": "namelesserlx",
        "email": "namelesslx@foxmail.com",
        "url": "https://github.com/namelesserlx"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/namelesserlx/codeless-blog.git"
    },
    "homepage": "https://blog.codeless.top/",
    "bugs": {
        "url": "https://github.com/namelesserlx/codeless-blog/issues"
    },
    "devDependencies": {
        "@blog/config": "workspace:*",
        "@eslint/js": "^9.39.4",
        "@commitlint/cli": "^19.8.1",
        "@commitlint/config-conventional": "^19.8.1",
        "globals": "^16.4.0",
        "@types/node": "^22.15.17",
        "@types/react": "^19.1.3",
        "@types/react-dom": "^19.1.3",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "husky": "^9.1.7",
        "lint-staged": "^15.5.2",
        "prettier": "^3.5.3",
        "prettier-plugin-tailwindcss": "^0.6.11",
        "prisma": "^7.6.0",
        "ts-node": "^10.9.2",
        "turbo": "^2.5.6",
        "typescript-eslint": "^8.58.0",
        "typescript": "^5.8.3",
        "vitest": "^4.1.2"
    },
    "lint-staged": {
        "*.{js,ts,jsx,tsx}": ["eslint --fix", "prettier --write"],
        "*.{json,md,css,less,scss}": ["prettier --write"]
    }
}
