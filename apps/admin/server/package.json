{
    "name": "@blog/server",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "scripts": {
        "dev": "cross-env NODE_ENV=development APP_ENV=development node ./scripts/dev-with-worker.mjs",
        "dev:app": "cross-env NODE_ENV=development APP_ENV=development ts-node-dev --files --respawn --transpile-only --notify=false src/app.ts",
        "build": "rm -rf dist && tsc",
        "lint": "eslint .",
        "test": "vitest run",
        "test:watch": "vitest",
        "start": "cross-env NODE_ENV=production node dist/app.js",
        "format": "prettier --write \"**/*.{js,ts,json,md}\"",
        "init-admin:dev": "cross-env NODE_ENV=development APP_ENV=development ts-node-dev --files src/scripts/init-admin.ts",
        "init-admin:prod": "cross-env NODE_ENV=production ts-node-dev --files src/scripts/init-admin.ts",
        "init-search:dev": "cross-env NODE_ENV=development APP_ENV=development ts-node-dev --files src/scripts/init-meilisearch.ts",
        "init-search:prod": "cross-env NODE_ENV=production ts-node --files src/scripts/init-meilisearch.ts",
        "sync-permissions:dev": "pnpm --filter @blog/shared build && cross-env NODE_ENV=development APP_ENV=development ts-node --files src/scripts/sync-permissions.ts",
        "sync-permissions:prod": "pnpm --filter @blog/shared build && cross-env NODE_ENV=production ts-node --files src/scripts/sync-permissions.ts",
        "metrics:worker:dev": "cross-env NODE_ENV=development APP_ENV=development ts-node-dev --files src/scripts/flush-metrics.ts",
        "metrics:worker:prod": "cross-env NODE_ENV=production node dist/scripts/flush-metrics.js",
        "deploy:dev": "pnpm build && pm2 start ecosystem.config.js --only blog-admin-server-dev,blog-admin-metrics-worker-dev",
        "deploy:prod": "pnpm build && pm2 start ecosystem.config.js --only blog-admin-server-prod,blog-admin-metrics-worker-prod",
        "stop": "pm2 stop all",
        "reload": "pm2 reload all",
        "delete": "pm2 delete all",
        "list": "pm2 list",
        "logs": "pm2 logs",
        "clean": "pkill -9 -f 'ts-node-dev.*app.ts' 2>/dev/null || true && pkill -9 -f 'ts-node-dev.*flush-metrics.ts' 2>/dev/null || true && lsof -ti :8000 | xargs kill -9 2>/dev/null || echo '✅ 端口 8000 已清理'"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/jsonwebtoken": "^9.0.8",
        "@types/koa": "^3.0.1",
        "@types/koa-bodyparser": "^4.3.13",
        "@types/koa-logger": "^3.1.5",
        "@types/koa__cors": "^5.0.0",
        "@types/koa__multer": "^2.0.7",
        "@types/koa__router": "^12.0.5",
        "@types/node": "^22.19.1",
        "@types/uuid": "^10.0.0",
        "cross-env": "^7.0.3",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.7.3",
        "vitest": "^4.1.2"
    },
    "dependencies": {
        "@blog/db": "workspace:*",
        "@blog/shared": "workspace:*",
        "@joyu/node-ip2region": "^3.0.2",
        "@koa/cors": "^5.0.0",
        "@koa/multer": "^4.0.0",
        "@koa/router": "^14.0.0",
        "@opentelemetry/api": "^1.9.1",
        "@opentelemetry/auto-instrumentations-node": "^0.73.0",
        "@opentelemetry/exporter-metrics-otlp-http": "^0.215.0",
        "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
        "@opentelemetry/sdk-metrics": "^2.7.0",
        "@opentelemetry/sdk-node": "^0.215.0",
        "@opentelemetry/sdk-trace-base": "^2.7.0",
        "axios": "^1.9.0",
        "bcryptjs": "^2.4.3",
        "cos-nodejs-sdk-v5": "^2.14.6",
        "dayjs": "^1.11.19",
        "dotenv": "^16.6.1",
        "ioredis": "^5.4.2",
        "jsonwebtoken": "^9.0.2",
        "koa": "^3.1.1",
        "koa-bodyparser": "^4.4.1",
        "koa-jwt": "^4.0.4",
        "koa-logger": "^4.0.0",
        "koa-static": "^5.0.0",
        "koa-swagger-decorator": "^1.8.7",
        "meilisearch": "^0.54.0",
        "module-alias": "^2.2.3",
        "nanoid": "^3.3.11",
        "nodemailer": "^7.0.11",
        "redis": "^5.10.0",
        "svg-captcha": "^1.4.0",
        "ua-parser-js": "^2.0.4",
        "uuid": "^11.1.0",
        "ws": "^8.19.0"
    }
}
