{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
            "env": ["NODE_ENV", "APP_ENV"]
        },
        "dev": {
            "dependsOn": ["^build"],
            "cache": false,
            "persistent": true
        },
        "lint": {
            "dependsOn": ["^build"],
            "outputs": []
        },
        "format": {
            "outputs": []
        },
        "db:generate": {
            "dependsOn": ["^build"],
            "cache": false
        },
        "db:push": {
            "dependsOn": ["^build"],
            "cache": false
        },
        "db:studio": {
            "dependsOn": ["^build"],
            "cache": false,
            "persistent": true
        },
        "db:migrate:dev": {
            "dependsOn": ["^build"],
            "cache": false
        },
        "db:migrate:deploy": {
            "dependsOn": ["^build"],
            "cache": false
        },
        "db:reset": {
            "dependsOn": ["^build"],
            "cache": false
        },
        "db:seed": {
            "dependsOn": ["^build"],
            "cache": false
        },
        "db:sync-permissions": {
            "dependsOn": ["^build"],
            "cache": false
        }
    },
    "globalEnv": [
        "NODE_ENV",
        "APP_ENV",
        "DATABASE_URL",
        "BLOG_PUBLIC_URL",
        "ADMIN_PUBLIC_URL",
        "API_PUBLIC_URL",
        "NEXT_PUBLIC_GITHUB_CLIENT_ID",
        "NEXT_PUBLIC_GOOGLE_CLIENT_ID",
        "VITE_GITHUB_ID",
        "VITE_GOOGLE_ID"
    ]
}
