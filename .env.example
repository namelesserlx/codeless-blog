# Blog Monorepo 环境变量唯一权威模板
# 使用方式：
# 1. 本地开发：cp .env.example .env.development
# 2. 测试部署：cp .env.example .env.staging
# 3. 正式部署：cp .env.example .env.production
# 4. 复制后请先修改 APP_ENV，再按实际环境填写下面的值
# 5. 如需单应用局部覆盖，再创建 apps/<app>/.env.{APP_ENV}

# 当前环境（必填）
# 可选值：development / staging / production
APP_ENV=development

# =========================
# 一、基础必填：所有环境都应配置
# =========================

# 数据库连接（必填）
# 运行期连接地址。Docker 一键部署时请填写容器内可访问的数据库地址。
DATABASE_URL=mysql://root:12345678@127.0.0.1:3306/blog_db

# blog 构建阶段数据库连接（可选）
# 仅在 Docker 一键部署且 next build 需要连库时配置；不填则回退到 DATABASE_URL
BLOG_BUILD_DATABASE_URL=

# Redis 连接（必填）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# 后台服务端鉴权密钥（必填）
JWT_SECRET=replace-with-a-long-random-jwt-secret

# 对外访问地址（必填）
BLOG_PUBLIC_URL=http://localhost:3000
ADMIN_PUBLIC_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:8000

# =========================
# 二、服务端运行必填
# =========================

# 后台服务端监听端口（必填）
PORT=8000

# 允许访问后台服务端的后台前端来源（必填）
ADMIN_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Token / Session / 验证码配置（建议保留默认值，如有需要再调整）
ACCESS_TOKEN_TTL_SECONDS=86400
SESSION_TTL_SECONDS=604800
CAPTCHA_TTL_SECONDS=300
AUTH_SESSION_COOKIE_NAME=sid
SESSION_COOKIE_MAX_AGE_MS=604800000
CAPTCHA_COOKIE_NAME=captcha_id
CAPTCHA_COOKIE_MAX_AGE_MS=300000
COOKIE_SECURE=false
COOKIE_DOMAIN=
COOKIE_SECURE_PROXY_HOSTS=
DASHBOARD_PUSH_INTERVAL_MS=15000
METRICS_FLUSH_INTERVAL_MS=60000

# OpenTelemetry 可观测性配置（可选，默认不启用）
OTEL_ENABLED=false
OTEL_SERVICE_NAME=blog-admin-server
OTEL_SERVICE_VERSION=
OTEL_ENVIRONMENT=development
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_TRACES_SAMPLE_RATE_PERCENT=100

# 登录/session 来源地解析（可选）
# 使用 ip2region xdb 本地库，不配置时登录不受影响，地址显示为“未知ip”
# 本地示例：/path/to/ip2region_v4.xdb
IP2REGION_XDB_PATH=

# =========================
# 三、搜索功能：启用 MeiliSearch 时必填
# 不使用搜索功能时，这一组可以留空
# =========================

MEILI_URL=
MEILI_ADMIN_KEY=
MEILI_SEARCH_KEY=

# =========================
# 四、OAuth / GitHub：按功能开启
# 不使用对应功能时，可以留空
# =========================

NEXT_PUBLIC_GITHUB_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GITHUB_TOKEN=
VITE_GITHUB_ID=
VITE_GOOGLE_ID=

# =========================
# 五、后台可选集成：按功能开启
# 不使用对应功能时，可以留空
# =========================

# 邮件
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM_NAME=Blog Admin
EMAIL_FROM_ADDRESS=

# COS 对象存储
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=ap-guangzhou
COS_CUSTOM_DOMAIN=
COS_SLICE_SIZE=52428800

# GitHub / Google OAuth 服务端密钥
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_NEXT_CLIENT_ID=
GITHUB_NEXT_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_NEXT_CLIENT_ID=
GOOGLE_NEXT_CLIENT_SECRET=
GOOGLE_OAUTH_PROXY_URL=

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# =========================
# 六、Docker 自托管额外变量
# 只在 docker compose 一键部署时使用
# 非 Docker 场景可忽略
# =========================

BLOG_PORT=3000
ADMIN_CLIENT_PORT=8080
ADMIN_SERVER_PORT=8000
MYSQL_PORT=3306
MYSQL_DATABASE=blog
MYSQL_USER=blog
MYSQL_PASSWORD=blog123456
MYSQL_ROOT_PASSWORD=root123456
MEILI_PORT=7700

# 仅在启用 Docker 内置 MeiliSearch 时填写；留空则关闭搜索服务
MEILI_MASTER_KEY=
